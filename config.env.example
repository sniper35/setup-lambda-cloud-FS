#!/usr/bin/env bash
# Lambda Cloud Persistent Dev Environment Configuration
# Edit these values before running first-time-setup.sh

# Lambda Cloud settings
LAMBDA_REGION="us-west-3"           # Change to your region
LAMBDA_FS_NAME="dev-env"
LAMBDA_FS_MOUNT="/lambda/nfs/dev-env"

# Git identity
GIT_USER_NAME="YOUR_NAME"
GIT_USER_EMAIL="YOUR_EMAIL"

# SSH key (path on persistent FS)
SSH_KEY_PATH="${LAMBDA_FS_MOUNT}/home/.ssh/id_ed25519"

# Node.js version for Claude Code / Codex
NODE_VERSION="22"

# Lambda API settings (for launch-instance.sh)
# Set LAMBDA_API_KEY as an environment variable, not here (security)
# export LAMBDA_API_KEY="your-api-key"
# Optionally set a default SSH key name for API launches:
# LAMBDA_SSH_KEY_NAME="my-ssh-key"
